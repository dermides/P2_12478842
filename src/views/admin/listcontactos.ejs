<%- include('../layouts/header', {titulopage: 'Panel Administrador' }); -%>
<%- include('../layouts/navbar-admin.ejs'); -%>
<section class="section mt-6 mb-4">
  <h2 class="title is-2">Listado de Contactos</h2>
  <div class="content is-normal">
  <table id="tabla" class="table">
      <thead>
        <tr>
          <th><abbr title="Position">ID</abbr></th>
          <th>Nombre</th>
          <th><abbr title="Played">Email</abbr></th>
          <th><abbr title="Won">Comentario</abbr></th>
          <th><abbr title="Drawn">IP</abbr></th>
          <th><abbr title="Lost">Fecha</abbr></th>
          
        </tr>
      </thead>
      
      <tbody>
        <% contactos.forEach(function(contacto){ %>
        <tr>
          <th><%= contacto.id %></th>
          <td><%= contacto.nombre %></td>
          <td><%= contacto.email %></td>         
          <td><%= contacto.comentario %></td>
          <td><%= contacto.direccion_ip %></td>
          <td><%= contacto.fecha_at.toLocaleDateString() %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</section>

  <%- include('../layouts/footer'); -%>